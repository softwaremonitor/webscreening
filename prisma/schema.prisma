generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A website to scan for packaging-related news.
model Source {
  id              String   @id @default(cuid())
  name            String
  homepageUrl     String   @unique
  feedUrl         String?
  sitemapUrl      String?
  fetchStrategy   String   @default("auto") // auto | rss | sitemap | html
  defaultLanguage String? // hint: fr, en, de, it, es, ...
  perDayLimit     Int      @default(10)
  enabled         Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  articles    Article[]
  batchErrors BatchSourceError[]

  @@index([enabled])
}

/// A keyword or quoted phrase used to filter incoming articles.
model Keyword {
  id        String   @id @default(cuid())
  /// Raw text as entered. Quoted phrases keep their quotes (e.g. "Bottle Collective").
  text      String   @unique
  /// True if the original text was a quoted phrase (exact match required).
  isPhrase  Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

/// A detected news article.
model Article {
  id              String   @id @default(cuid())
  source          Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId        String
  originalTitle   String
  shortTitle      String // truncated to ≤50 chars for display
  excerpt         String // ≤200 chars + "..." (built at insert time)
  rawExcerpt      String? // full pre-truncation excerpt for future translation
  rawContent      String? // optional fetched main content
  url             String
  canonicalUrl    String   @unique
  publishedAt     DateTime
  detectedAt      DateTime @default(now())
  language        String?
  status          String   @default("published") // published | hidden
  matchedKeywords String // JSON array of keyword texts that triggered the match
  createdAt       DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([sourceId, publishedAt])
  @@index([status])
}

/// A run of the batch worker.
model BatchRun {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    @default("running") // running | success | failed | partial
  mode            String    @default("daily") // daily | backfill | manual
  sourcesAnalyzed Int       @default(0)
  articlesFound   Int       @default(0)
  articlesAdded   Int       @default(0)
  errorCount      Int       @default(0)
  message         String?
  durationMs      Int?
  errors          BatchSourceError[]

  @@index([startedAt(sort: Desc)])
}

/// A per-source error captured during a batch run.
model BatchSourceError {
  id        String   @id @default(cuid())
  batch     BatchRun @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId   String
  source    Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId  String
  message   String
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([sourceId])
}
